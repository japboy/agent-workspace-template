packages:
  - ".agents/skills"
  - "apps/*"
  - "packages/*"

# Supply-chain policy
#
# Only packages mature for at least three days are eligible for resolution.
# Missing registry timestamps fail closed rather than bypassing this policy.
minimumReleaseAge: 4320
minimumReleaseAgeStrict: true
minimumReleaseAgeIgnoreMissingTime: false

# Reject a package release whose publisher trust evidence is weaker than an
# earlier release, and re-verify these checks for every lockfile entry.
trustPolicy: no-downgrade
trustLockfile: false

# Transitive Git and tarball dependencies are not allowed. Dependencies that
# execute lifecycle build scripts must be reviewed explicitly below.
blockExoticSubdeps: true
strictDepBuilds: true
allowBuilds: {}

# Fail on undeclared or incompatible peer dependencies, stale installations,
# and dependencies incompatible with the pinned Node.js runtime.
strictPeerDependencies: true
verifyDepsBeforeRun: error
nodeVersion: {{ tool_versions.nodejs }}
engineStrict: true

# New direct dependencies are recorded as exact versions by default.
savePrefix: ""
